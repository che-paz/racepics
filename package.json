{
  "name": "racepics",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "dev:clean": "rm -rf .next node_modules/.cache && next dev -p 3002",
    "clean": "rm -rf .next node_modules/.cache",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:start": "supabase start",
    "db:reset": "supabase db reset",
    "db:stop": "supabase stop",
    "db:keys": "supabase status --output env | grep -E '^(API_URL|ANON_KEY|SERVICE_ROLE_KEY)='",
    "inngest:dev": "npx inngest-cli@latest dev -u http://localhost:3002/api/inngest"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@google-cloud/vision": "^5.3.7",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "archiver": "^8.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "inngest": "^4.7.0",
    "lucide-react": "^1.21.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "shadcn": "^4.11.0",
    "sharp": "^0.35.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "supabase": "^2.107.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
