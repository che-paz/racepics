# Supabase — cloud (desarrollo actual)
# Local Docker opcional; ver stack-tecnologico.md
NEXT_PUBLIC_SUPABASE_URL=https://TU-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Cloud Vision (Sprint 4+)
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
# En Vercel: JSON inline del service account
GOOGLE_CREDENTIALS_JSON=

# Inngest (Sprint 4+)
# Local: INNGEST_DEV=1 + npm run inngest:dev (no hace falta event/signing key)
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# App
# Local: http://localhost:3002
# Production (Vercel): https://tu-dominio.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3002
